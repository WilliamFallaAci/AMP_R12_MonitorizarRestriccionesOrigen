          <ui:InvokeCode ContinueOnError="{x:Null}" Code="Try&#xA;    ' 1. Configurar la cadena de conexión para Excel (.xlsx)&#xA;    ' IMEX=1 le dice al motor que lea datos mixtos (números y texto) como texto para evitar valores nulos.&#xA;    ' HDR=No indica que no use la primera fila como encabezado.&#xA;    Dim strConex As String = &quot;Provider=Microsoft.ACE.OLEDB.12.0;Data Source=&quot; &amp; in_RutaExcel &amp; &quot;;Extended Properties='Excel 12.0 Xml;HDR=No;IMEX=1';&quot;&#xA;    &#xA;    Dim dtTemporal As New System.Data.DataTable()&#xA;&#xA;    ' 2. Conectar al archivo y extraer los datos de la primera hoja&#xA;    Using conexion As New System.Data.OleDb.OleDbConnection(strConex)&#xA;        conexion.Open()&#xA;        &#xA;        ' Obtenemos el nombre de la primera hoja dinámicamente&#xA;        Dim dtEsquema As System.Data.DataTable = conexion.GetOleDbSchemaTable(System.Data.OleDb.OleDbSchemaGuid.Tables, Nothing)&#xA;        Dim nombreHoja As String = dtEsquema.Rows(0)(&quot;TABLE_NAME&quot;).ToString()&#xA;        &#xA;        ' Traemos toda la información de esa hoja&#xA;        Dim query As String = &quot;SELECT * FROM [&quot; &amp; nombreHoja &amp; &quot;]&quot;&#xA;        &#xA;        Using comando As New System.Data.OleDb.OleDbCommand(query, conexion)&#xA;            Using adaptador As New System.Data.OleDb.OleDbDataAdapter(comando)&#xA;                adaptador.Fill(dtTemporal)&#xA;            End Using&#xA;        End Using&#xA;    End Using&#xA;&#xA;    ' 3. Lógica para simular el rango A2 (Omitir la primera fila del archivo)&#xA;    If dtTemporal.Rows.Count &gt; 0 Then&#xA;        ' Clonamos la estructura de la tabla (columnas)&#xA;        out_dtDatos = dtTemporal.Clone()&#xA;        &#xA;        ' Importamos todas las filas a partir del índice 1 (que es la segunda fila del Excel)&#xA;        For i As Integer = 1 To dtTemporal.Rows.Count - 1&#xA;            out_dtDatos.ImportRow(dtTemporal.Rows(i))&#xA;        Next&#xA;    Else&#xA;        ' Si el archivo estaba completamente vacío&#xA;        out_dtDatos = dtTemporal&#xA;    End If&#xA;&#xA;Catch ex As Exception&#xA;    ' Captura cualquier error estructural y lo eleva a UiPath&#xA;    Throw New Exception(&quot;Error al leer el Excel mediante Invoke Code: &quot; &amp; ex.Message)&#xA;End Try" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="416,188" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
