    <ui:InvokeCode ContinueOnError="{x:Null}" Code="Dim excelApp As Microsoft.Office.Interop.Excel.Application = Nothing&#xD;&#xA;Dim excelWorkbook As Microsoft.Office.Interop.Excel.Workbook = Nothing&#xD;&#xA;&#xD;&#xA;Try&#xD;&#xA;    ' Inicializar la aplicación de Excel de fondo&#xD;&#xA;    excelApp = New Microsoft.Office.Interop.Excel.Application()&#xD;&#xA;    excelApp.Visible = False ' Cambiar a True si deseas ver el proceso&#xD;&#xA;    excelApp.DisplayAlerts = False ' Evita ventanas emergentes que detengan el script&#xD;&#xA;&#xD;&#xA;    ' Abrir el libro de Excel&#xD;&#xA;    excelWorkbook = excelApp.Workbooks.Open(in_WorkbookPath)&#xD;&#xA;&#xD;&#xA;    ' Ejecutar la macro&#xD;&#xA;    excelApp.Run(in_MacroName)&#xD;&#xA;&#xD;&#xA;    ' Guardar y cerrar el libro&#xD;&#xA;    excelWorkbook.Save()&#xD;&#xA;    excelWorkbook.Close(True)&#xD;&#xA;&#xD;&#xA;Catch ex As Exception&#xD;&#xA;    ' Capturar y relanzar cualquier error para que UiPath lo detecte&#xD;&#xA;    Throw New Exception(&quot;Error al ejecutar la macro de Excel: &quot; &amp; ex.Message)&#xD;&#xA;&#x9;outException = ex.Message&#xD;&#xA;&#xD;&#xA;Finally&#xD;&#xA;    ' Limpieza absoluta de los objetos COM para evitar que Excel se quede colgado en administrador de tareas&#xD;&#xA;    If excelWorkbook IsNot Nothing Then&#xD;&#xA;        System.Runtime.InteropServices.Marshal.ReleaseComObject(excelWorkbook)&#xD;&#xA;    End If&#xD;&#xA;    &#xD;&#xA;    If excelApp IsNot Nothing Then&#xD;&#xA;        excelApp.Quit()&#xD;&#xA;        System.Runtime.InteropServices.Marshal.ReleaseComObject(excelApp)&#xD;&#xA;    End If&#xD;&#xA;    &#xD;&#xA;    ' Forzar la recolección de basura por seguridad&#xD;&#xA;    GC.Collect()&#xD;&#xA;    GC.WaitForPendingFinalizers()&#xD;&#xA;End Try" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="450,197" sap2010:WorkflowViewState.IdRef="InvokeCode_3">
