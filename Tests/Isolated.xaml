    <ui:InvokeCode ContinueOnError="{x:Null}" Code="' Usamos la codificación ISO-8859-1 que es nativa y compatible con los reportes ANSI de SAP&#xD;&#xA;Dim enc As System.Text.Encoding = System.Text.Encoding.GetEncoding(&quot;ISO-8859-1&quot;)&#xD;&#xA;&#xD;&#xA;' Leer todas las líneas usando la codificación correcta&#xD;&#xA;Dim lineas As String() = File.ReadAllLines(in_FilePath, enc)&#xD;&#xA;&#xD;&#xA;Dim dt As New System.Data.DataTable()&#xD;&#xA;Dim encabezadoDetectado As Boolean = False&#xD;&#xA;&#xD;&#xA;For Each linea As String In lineas&#xD;&#xA;    Dim lineaLimpia As String = linea.Trim()&#xD;&#xA;    &#xD;&#xA;    ' 1. Ignorar líneas vacías, divisorias (---) o metadatos de SAP&#xD;&#xA;    If String.IsNullOrEmpty(lineaLimpia) OrElse lineaLimpia.StartsWith(&quot;-&quot;) OrElse lineaLimpia.Contains(&quot;Salida&quot;) Then&#xD;&#xA;        Continue For&#xD;&#xA;    End If&#xD;&#xA;    &#xD;&#xA;    ' 2. Verificar que la línea realmente contenga el caracter pipe '|'&#xD;&#xA;    If Not lineaLimpia.Contains(&quot;|&quot;) Then&#xD;&#xA;        Continue For&#xD;&#xA;    End If&#xD;&#xA;&#xD;&#xA;    ' 3. Separar por pipe '|'&#xD;&#xA;    Dim partes As String() = lineaLimpia.Split(New Char() {&quot;|&quot;c})&#xD;&#xA;    &#xD;&#xA;    ' Extraer solo las celdas internas (omitiendo el primer y último elemento vacío por los pipes de los extremos)&#xD;&#xA;    Dim celdasReales As New List(Of String)()&#xD;&#xA;    For i As Integer = 1 To partes.Length - 2&#xD;&#xA;        celdasReales.Add(partes(i).Trim())&#xD;&#xA;    Next&#xD;&#xA;&#xD;&#xA;    ' 4. Procesar el Encabezado de la tabla&#xD;&#xA;    If Not encabezadoDetectado Then&#xD;&#xA;        ' Comprobamos si es la fila de títulos buscando la columna Ce.&#xD;&#xA;        If celdasReales.Count &gt; 0 AndAlso celdasReales(0).StartsWith(&quot;Ce.&quot;) Then&#xD;&#xA;            For Each columna As String In celdasReales&#xD;&#xA;                Dim nombreCol As String = columna&#xD;&#xA;                Dim contador As Integer = 1&#xD;&#xA;                While dt.Columns.Contains(nombreCol)&#xD;&#xA;                    nombreCol = columna &amp; &quot;_&quot; &amp; contador&#xD;&#xA;                    contador += 1&#xD;&#xA;                End While&#xD;&#xA;                dt.Columns.Add(nombreCol)&#xD;&#xA;            Next&#xD;&#xA;            encabezadoDetectado = True&#xD;&#xA;        End If&#xD;&#xA;    Else&#xD;&#xA;        ' 5. Procesar las Filas de datos&#xD;&#xA;        If celdasReales.Count = dt.Columns.Count Then&#xD;&#xA;            dt.Rows.Add(celdasReales.ToArray())&#xD;&#xA;        End If&#xD;&#xA;    End If&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;out_Dt = dt" DisplayName="Execute VB.Net code to read file and populate data table" sap:VirtualizedContainerService.HintSize="450,197" sap2010:WorkflowViewState.IdRef="InvokeCode_5">
