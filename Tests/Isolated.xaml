    <ui:InvokeCode ContinueOnError="{x:Null}" Code="Try&#xA;    ' 1. Configurar la cadena de conexión&#xA;    ' Al cambiar HDR=Yes, forzamos a que la fila 1 (A1) se convierta en el nombre de las columnas,&#xA;    ' logrando que el contenido de la DataTable empiece estrictamente desde la fila 2 (A2).&#xA;    Dim strConex As String = &quot;Provider=Microsoft.ACE.OLEDB.12.0;Data Source=&quot; &amp; in_RutaExcel &amp; &quot;;Extended Properties='Excel 12.0 Xml;HDR=Yes;IMEX=1';&quot;&#xA;    &#xA;    Dim dtTemporal As New System.Data.DataTable()&#xA;&#xA;    ' 2. Conectar al archivo y extraer los datos de la primera hoja&#xA;    Using conexion As New System.Data.OleDb.OleDbConnection(strConex)&#xA;        conexion.Open()&#xA;        &#xA;        ' Obtener el nombre de la primera hoja dinámicamente&#xA;        Dim dtEsquema As System.Data.DataTable = conexion.GetOleDbSchemaTable(System.Data.OleDb.OleDbSchemaGuid.Tables, Nothing)&#xA;        Dim nombreHoja As String = dtEsquema.Rows(0)(&quot;TABLE_NAME&quot;).ToString()&#xA;        &#xA;        ' Seleccionar todos los registros (que ahora iniciarán en la fila 2)&#xA;        Dim query As String = &quot;SELECT * FROM [&quot; &amp; nombreHoja &amp; &quot;]&quot;&#xA;        &#xA;        Using comando As New System.Data.OleDb.OleDbCommand(query, conexion)&#xA;            Using adaptador As New System.Data.OleDb.OleDbDataAdapter(comando)&#xA;                adaptador.Fill(dtTemporal)&#xA;            End Using&#xA;        End Using&#xA;    End Using&#xA;&#xA;    ' 3. Asignar el resultado al argumento de salida de UiPath&#xA;    out_dtDatos = dtTemporal&#xA;&#xA;Catch ex As Exception&#xA;    ' Captura cualquier error y lo envía a la consola de UiPath&#xA;    Throw New Exception(&quot;Error al leer el Excel desde A2 en Invoke Code: &quot; &amp; ex.Message)&#xA;End Try" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="450,197" sap2010:WorkflowViewState.IdRef="InvokeCode_2">
