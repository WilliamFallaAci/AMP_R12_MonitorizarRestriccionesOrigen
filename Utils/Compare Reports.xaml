    <ui:InvokeCode ContinueOnError="{x:Null}" Code="' 1. Inicializar la tabla de resultados y crear las columnas intercaladas&#xD;&#xA;out_dtResultados = New DataTable()&#xD;&#xA; &#xD;&#xA;For Each col As DataColumn In in_TableReport.Columns&#xD;&#xA;    out_dtResultados.Columns.Add(col.ColumnName &amp; &quot;_Dt1&quot;, col.DataType)&#xD;&#xA;    out_dtResultados.Columns.Add(col.ColumnName &amp; &quot;_Dt2&quot;, col.DataType)&#xD;&#xA;Next&#xD;&#xA; &#xD;&#xA;' 2. Determinar el límite de filas para evitar errores de índice fuera de rango&#xD;&#xA;Dim maxFilas As Integer = Math.Min(dt1.Rows.Count, in_TableReport_Aux.Rows.Count)&#xD;&#xA; &#xD;&#xA;' 3. Recorrer y comparar fila por fila (1:1)&#xD;&#xA;For i As Integer = 0 To maxFilas - 1&#xD;&#xA;    Dim fila1 As DataRow = in_TableReport.Rows(i)&#xD;&#xA;    Dim fila2 As DataRow = in_TableReport_Aux.Rows(i)&#xD;&#xA;    ' Compara si toda la fila es idéntica&#xD;&#xA;    If Not DataRowComparer.Default.Equals(fila1, fila2) Then&#xD;&#xA;        ' Si hay diferencias, creamos el array intercalado (ColA_Dt1, ColA_Dt2...)&#xD;&#xA;        Dim valoresIntercalados As New List(Of Object)()&#xD;&#xA;        For c As Integer = 0 To in_TableReport.Columns.Count - 1&#xD;&#xA;            valoresIntercalados.Add(fila1(c))&#xD;&#xA;            valoresIntercalados.Add(fila2(c))&#xD;&#xA;        Next&#xD;&#xA;        ' Añadir la fila con las diferencias a la tabla de resultados&#xD;&#xA;        out_dtResultados.Rows.Add(valoresIntercalados.ToArray())&#xD;&#xA;    End If&#xD;&#xA;Next" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="450,197" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
