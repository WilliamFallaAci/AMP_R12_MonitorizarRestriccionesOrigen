    <ui:InvokeCode ContinueOnError="{x:Null}" sap2010:Annotation.AnnotationText="Find diferences" Code="' 1. Inicializar la tabla de resultados (DT3)&#xD;&#xA;out_TableResults = New DataTable()&#xD;&#xA;&#xD;&#xA;' Agregar columnas A y B fijas al inicio como identificadores del reporte&#xD;&#xA;out_TableResults.Columns.Add(in_TableReport.Columns(0).ColumnName, in_TableReport.Columns(0).DataType)&#xD;&#xA;out_TableResults.Columns.Add(in_TableReport.Columns(1).ColumnName, in_TableReport.Columns(1).DataType)&#xD;&#xA;&#xD;&#xA;' Agregar las columnas restantes de forma intercalada (Desde el índice 2 en adelante)&#xD;&#xA;For c As Integer = 2 To in_TableReport.Columns.Count - 1&#xD;&#xA;    Dim nombreCol As String = in_TableReport.Columns(c).ColumnName&#xD;&#xA;    Dim tipoCol As Type = in_TableReport.Columns(c).DataType&#xD;&#xA;    out_TableResults.Columns.Add(nombreCol &amp; &quot;_Dt1&quot;, tipoCol)&#xD;&#xA;    out_TableResults.Columns.Add(nombreCol &amp; &quot;_Dt2&quot;, tipoCol)&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' 2. Indexar in_TableReport_Aux (DT2) en un Diccionario para búsquedas instantáneas&#xD;&#xA;' La clave será la concatenación de la Columna A y Columna B -&gt; &quot;ValorA|ValorB&quot;&#xD;&#xA;Dim diccionarioAux As New Dictionary(Of String, DataRow)()&#xD;&#xA;&#xD;&#xA;For Each filaAux As DataRow In in_TableReport_Aux.Rows&#xD;&#xA;    ' Convertimos a String controlando posibles valores Nulos (DBNull)&#xD;&#xA;    Dim claveA As String = If(Convert.IsDBNull(filaAux(0)), &quot;&quot;, filaAux(0).ToString().Trim())&#xD;&#xA;    Dim claveB As String = If(Convert.IsDBNull(filaAux(1)), &quot;&quot;, filaAux(1).ToString().Trim())&#xD;&#xA;    Dim llaveCompuesta As String = claveA &amp; &quot;|&quot; &amp; claveB&#xD;&#xA;    &#xD;&#xA;    ' Evitamos errores por llaves duplicadas en el Auxiliar&#xD;&#xA;    If Not diccionarioAux.ContainsKey(llaveCompuesta) Then&#xD;&#xA;        diccionarioAux.Add(llaveCompuesta, filaAux)&#xD;&#xA;    End If&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' 3. Recorrer in_TableReport (DT1) y buscar coincidencias en el diccionario&#xD;&#xA;For Each filaReport As DataRow In in_TableReport.Rows&#xD;&#xA;    Dim claveA As String = If(Convert.IsDBNull(filaReport(0)), &quot;&quot;, filaReport(0).ToString().Trim())&#xD;&#xA;    Dim claveB As String = If(Convert.IsDBNull(filaReport(1)), &quot;&quot;, filaReport(1).ToString().Trim())&#xD;&#xA;    Dim llaveCompuesta As String = claveA &amp; &quot;|&quot; &amp; claveB&#xD;&#xA;    &#xD;&#xA;    ' SI hay MATCH en el Dt2 (Auxiliar)&#xD;&#xA;    If diccionarioAux.ContainsKey(llaveCompuesta) Then&#xD;&#xA;        Dim filaAux As DataRow = diccionarioAux(llaveCompuesta)&#xD;&#xA;        Dim existeDiferencia As Boolean = False&#xD;&#xA;        &#xD;&#xA;        ' Validar desde la columna C (índice 2) hasta la última si hay diferencias&#xD;&#xA;        For c As Integer = 2 To in_TableReport.Columns.Count - 1&#xD;&#xA;            If Not Object.Equals(filaReport(c), filaAux(c)) Then&#xD;&#xA;                existeDiferencia = True&#xD;&#xA;                Exit For ' Fila marcada, salimos del bucle de columnas&#xD;&#xA;            End If&#xD;&#xA;        Next&#xD;&#xA;        &#xD;&#xA;        ' Si se detectó al menos una diferencia, armamos la fila de resultados (DT3)&#xD;&#xA;        If existeDiferencia Then&#xD;&#xA;            Dim valoresFila As New List(Of Object)()&#xD;&#xA;            &#xD;&#xA;            ' Conservamos la llave original (Columnas A y B)&#xD;&#xA;            valoresFila.Add(filaReport(0))&#xD;&#xA;            valoresFila.Add(filaReport(1))&#xD;&#xA;            &#xD;&#xA;            ' Intercalamos los valores de las columnas comparadas&#xD;&#xA;            For c As Integer = 2 To in_TableReport.Columns.Count - 1&#xD;&#xA;                valoresFila.Add(filaReport(c))&#xD;&#xA;                valoresFila.Add(filaAux(c))&#xD;&#xA;            Next&#xD;&#xA;            &#xD;&#xA;            ' Añadir la fila con las diferencias al DataTable out_TableResults&#xD;&#xA;            out_TableResults.Rows.Add(valoresFila.ToArray())&#xD;&#xA;        End If&#xD;&#xA;    End If&#xD;&#xA;Next" DisplayName="Monitor origin restrictions by processing data" sap:VirtualizedContainerService.HintSize="450,228" sap2010:WorkflowViewState.IdRef="InvokeCode_2">
