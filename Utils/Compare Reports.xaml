        <Sequence DisplayName="Ignored Activities" sap:VirtualizedContainerService.HintSize="450,248" sap2010:WorkflowViewState.IdRef="Sequence_2">
          <sap:WorkflowViewStateService.ViewState>
            <scg:Dictionary x:TypeArguments="x:String, x:Object">
              <x:Boolean x:Key="IsExpanded">True</x:Boolean>
            </scg:Dictionary>
          </sap:WorkflowViewStateService.ViewState>
          <ui:InvokeCode ContinueOnError="{x:Null}" Code="' 1. Inicializar la tabla de resultados&#xD;&#xA;out_dtResultados = New DataTable()&#xD;&#xA;&#xD;&#xA;' 2. Agregar columnas A y B fijas al inicio (Índices 0 y 1) como identificadores&#xD;&#xA;out_dtResultados.Columns.Add(in_TableReport.Columns(0).ColumnName, in_TableReport.Columns(0).DataType)&#xD;&#xA;out_dtResultados.Columns.Add(in_TableReport.Columns(1).ColumnName, in_TableReport.Columns(1).DataType)&#xD;&#xA;&#xD;&#xA;' 3. Agregar las columnas restantes de forma intercalada (Desde el índice 2 en adelante)&#xD;&#xA;For c As Integer = 2 To in_TableReport.Columns.Count - 1&#xD;&#xA;    Dim nombreCol As String = in_TableReport.Columns(c).ColumnName&#xD;&#xA;    Dim tipoCol As Type = in_TableReport.Columns(c).DataType&#xD;&#xA;    out_dtResultados.Columns.Add(nombreCol &amp; &quot;_Dt1&quot;, tipoCol)&#xD;&#xA;    out_dtResultados.Columns.Add(nombreCol &amp; &quot;_Dt2&quot;, tipoCol)&#xD;&#xA;Next&#xD;&#xA;&#xD;&#xA;' 4. Determinar el límite de filas para la comparación 1:1&#xD;&#xA;Dim maxFilas As Integer = Math.Min(in_TableReport.Rows.Count, in_TableReport_Aux.Rows.Count)&#xD;&#xA;&#xD;&#xA;' 5. Recorrer y comparar fila por fila&#xD;&#xA;For i As Integer = 0 To maxFilas - 1&#xD;&#xA;    Dim fila1 As DataRow = in_TableReport.Rows(i)&#xD;&#xA;    Dim fila2 As DataRow = in_TableReport_Aux.Rows(i)&#xD;&#xA;    Dim existeDiferencia As Boolean = False&#xD;&#xA;    &#xD;&#xA;    ' Comparamos ÚNICAMENTE desde el índice 2 (Columna C) en adelante&#xD;&#xA;    For c As Integer = 2 To in_TableReport.Columns.Count - 1&#xD;&#xA;        If Not Object.Equals(fila1(c), fila2(c)) Then&#xD;&#xA;            existeDiferencia = True&#xD;&#xA;            Exit For ' Fila marcada, salimos del bucle interno&#xD;&#xA;        End If&#xD;&#xA;    Next&#xD;&#xA;    &#xD;&#xA;    ' 6. Si se detectó una diferencia, estructuramos la fila de salida&#xD;&#xA;    If existeDiferencia Then&#xD;&#xA;        Dim valoresFila As New List(Of Object)()&#xD;&#xA;        &#xD;&#xA;        ' Conservamos los valores de control de las columnas A y B (del Dt1)&#xD;&#xA;        valoresFila.Add(fila1(0))&#xD;&#xA;        valoresFila.Add(fila1(1))&#xD;&#xA;        &#xD;&#xA;        ' Intercalamos los valores de las columnas comparadas&#xD;&#xA;        For c As Integer = 2 To in_TableReport.Columns.Count - 1&#xD;&#xA;            valoresFila.Add(fila1(c))&#xD;&#xA;            valoresFila.Add(fila2(c))&#xD;&#xA;        Next&#xD;&#xA;        &#xD;&#xA;        ' Añadir la fila al reporte&#xD;&#xA;        out_dtResultados.Rows.Add(valoresFila.ToArray())&#xD;&#xA;    End If&#xD;&#xA;Next" DisplayName="Process data for origin restrictions using custom code." sap:VirtualizedContainerService.HintSize="416,188" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
